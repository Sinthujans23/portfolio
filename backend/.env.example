# Get your free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address you want to receive contact messages at
TO_EMAIL=sinthuu07@gmail.com

# The "from" address — must be a domain you verified in Resend
# For testing you can use: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# Your GitHub username
GITHUB_USERNAME=Sinthujans23

# Optional: GitHub Personal Access Token for higher rate limits
# Create one at https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

PORT=3001

# Supabase admin access for server-side article deletes
# Use your project URL and service_role key from Supabase Project Settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Must match VITE_ADMIN_PASSWORD in frontend/.env for the article admin buttons.
ADMIN_PASSWORD=admin123
